<odoo>
    <data noupdate="1">
        <record id="group_real_estate.group_property_manager" model="res.groups">
            <field name="name">Real Estate/real_estate.group_property_manager</field>
            <field name="comment">Property Manager</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_real_estate.group_property_manager_real_estate_property" model="ir.model.access">
            <field name="name">real_estate.group_property_manager Access to real_estate.property</field>
            <field name="model_id" ref="real_estate_property"/>
            <field name="group_id" ref="group_real_estate.group_property_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="group_real_estate.group_property_user" model="res.groups">
            <field name="name">Real Estate/real_estate.group_property_user</field>
            <field name="comment">Property User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('real_estate.group_property_manager'))]"/>
        </record>

        <record id="access_real_estate.group_property_user_real_estate_property" model="ir.model.access">
            <field name="name">real_estate.group_property_user Access to real_estate.property</field>
            <field name="model_id" ref="real_estate_property"/>
            <field name="group_id" ref="group_real_estate.group_property_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
        </record>
    </data>
</odoo>